{
  "luci-app-olcrtc": {
    "description": "Права доступа для LuCI-приложения OlcRTC",
    "read": {
      "uci": [ "olcrtc" ],
      "ubus": {
        "service": [ "list" ],
        "uci": [ "get" ],
        "file": [ "exec", "read" ],
        "rc": [ "init" ]
      },
      "file": {
        "/sbin/logread": [ "exec" ],
        "/var/run/olcrtc.pid": [ "read" ]
      }
    },
    "write": {
      "uci": [ "olcrtc" ],
      "ubus": {
        "uci": [ "set", "commit" ],
        "service": [ "set", "call" ],
        "rc": [ "init" ]
      }
    }
  }
}
