#!/bin/sh /etc/rc.common
# Скрипт инициализации OlcRTC для OpenWRT
# Часть проекта OlcRTC-OpenWRT

USE_PROCD=1
START=95
STOP=10

PROG=/usr/bin/olcrtc
PIDFILE=/var/run/olcrtc.pid
LOGTAG="olcrtc"

start_service() {
    local carrier transport room_id client_id key socks_port dns

    config_load olcrtc
    config_get carrier    config carrier    'telemost'
    config_get transport  config transport  'vp8channel'
    config_get room_id    config room_id    ''
    config_get client_id  config client_id  ''
    config_get key        config key        ''
    config_get socks_port config socks_port '1080'
    config_get dns        config dns        '1.1.1.1:53'

    if [ -z "$room_id" ] || [ -z "$key" ]; then
        logger -t "$LOGTAG" "Ошибка: не заданы Room ID или ключ — запуск невозможен"
        return 1
    fi

    if [ -z "$client_id" ]; then
        logger -t "$LOGTAG" "Ошибка: не задан Client ID — запуск невозможен"
        return 1
    fi

    if [ ! -x "$PROG" ]; then
        logger -t "$LOGTAG" "Ошибка: бинарник $PROG не найден или не исполняемый"
        return 1
    fi

    logger -t "$LOGTAG" "Запуск клиента: carrier=$carrier transport=$transport порт=$socks_port"

    procd_open_instance
    procd_set_param command "$PROG" \
        -mode cnc \
        -carrier "$carrier" \
        -transport "$transport" \
        -id "$room_id" \
        -client-id "$client_id" \
        -key "$key" \
        -link direct \
        -data data \
        -dns "$dns" \
        -socks-host 0.0.0.0 \
        -socks-port "$socks_port"
    procd_set_param respawn 3600 5 0
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param pidfile "$PIDFILE"
    procd_close_instance
}

stop_service() {
    logger -t "$LOGTAG" "Остановка клиента"
}

service_triggers() {
    procd_add_reload_trigger "olcrtc"
}

reload_service() {
    stop
    start
}
